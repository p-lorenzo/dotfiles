# Mako configuration (Catppuccin Mocha with Glassmorphism)

# Layout
max-visible=5
sort=-time
layer=overlay
anchor=top-right
width=340
height=110
margin=8
outer-margin=60,20
padding=12

# Style
font=JetBrainsMono Nerd Font 10
border-size=1
border-radius=12
icons=1
max-icon-size=48
icon-border-radius=8
markup=1
format=<b>%s</b>\n%b

# Colors (Glassmorphism & Catppuccin Mocha)
# Base color: #1e1e2e at 65% opacity (a6)
background-color=#1e1e2ea6
text-color=#cdd6f4
# White border with 8% opacity (14)
border-color=#ffffff14
progress-color=over #89b4fa

[urgency=low]
border-color=#ffffff0c
default-timeout=4000

[urgency=normal]
border-color=#ffffff14
default-timeout=6000

[urgency=high]
border-color=#f38ba8a6
default-timeout=0
